<div class="bg-light-green page-min-height">

  <%= render "admin/breadcrumb", domain: "teachers" %>
  <div class="container">

    <% if @pendingTeachers.present? %>
      <div class="row">
        <div class="col m12">
          <p id="notice"><%= notice %></p>

          <h5 style="margin-top: 10px;" class="blue-text"><b>待定</b></h5>

          <table>
            <thead>
              <tr>
                <th>姓</th>
                <th>名字</th>
                <th>英语名</th>
                <th>年龄</th>
                <th>出生日期</th>
                <th>性别</th>
                <th>城市</th>
                <th>工作</th>
                <th colspan="3"></th>
              </tr>
            </thead>

            <tbody>
              <% @pendingTeachers.each do |teacher| %>
                <tr>
                  <td><%= teacher.lastname %></td>
                  <td><%= teacher.firstname %></td>
                  <td><%= teacher.englishname %></td>
                  <td><%= teacher.age %></td>
                  <td><%= teacher.birthday %></td>
                  <td><%= teacher.gender %></td>
                  <td><%= teacher.city %></td>
                  <td><%= teacher.work %></td>
                  <td><%= link_to '查看', teacher %></td>
                  <td><%= link_to '注销', teacher, method: :delete, data: { confirm: 'Are you sure?' } %></td>
                </tr>
              <% end %>
            </tbody>
          </table>

        </div>
      </div>
    <% end %>

    <div class="row">
      <div class="col m12">
        <h5 style="margin-top: 10px;" class="green-text"><b>在职教师</b></h5>

        <table>
          <thead>
            <tr>
              <th>姓</th>
              <th>名字</th>
              <th>英语名</th>
              <th>年龄</th>
              <th>出生日期</th>
              <th>性别</th>
              <th>城市</th>
              <th>工作</th>
              <th colspan="3"></th>
            </tr>
          </thead>

          <tbody>
            <% @activeTeachers.each do |teacher| %>
              <tr>
                <td><%= teacher.lastname %></td>
                <td><%= teacher.firstname %></td>
                <td><%= teacher.englishname %></td>
                <td><%= teacher.age %></td>
                <td><%= teacher.birthday %></td>
                <td><%= teacher.gender %></td>
                <td><%= teacher.city %></td>
                <td><%= teacher.work %></td>
                <td><%= link_to '查看', teacher %></td>
                <td><%= link_to '注销', teacher, method: :delete, data: { confirm: 'Are you sure?' } %></td>
              </tr>
            <% end %>
          </tbody>
        </table>

      </div>
    </div>
    <br>
  </div>
</div>