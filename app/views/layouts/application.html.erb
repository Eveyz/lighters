<!DOCTYPE html>
<!--
    _/         _/_/_/  _/_/_/    _/    _/   _/_/_/_/  _/_/_/_/  _/_/_/_/  _/_/_/_/
   _/          _/     _/        _/    _/      _/     _/        _/    _/  _/ 
  _/          _/     _/  _/    _/_/_/_/      _/     _/_/_/    _/_/_/_/   _/_/_/_/
 _/          _/     _/  _/    _/    _/      _/     _/        _/ _/            _/
_/_/_/_/  _/_/_/   _/_/_/_/  _/    _/      _/     _/_/_/_/  _/   _/_/  _/_/_/_/

Interested in working with us? See https://www.lighters.com/careers.
-->
<html>
  <head>
    <title>Lighters</title>
    <%= csrf_meta_tags %>

    <%= stylesheet_link_tag    'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application' %>
    <%= stylesheet_pack_tag 'application' %>
  </head>

  <body>

    <% if controller_name == "students" and action_name == "me" %>
      <%= render "students/student_header" %>
    <% elsif controller_name == "mainpages" and action_name == "welcome" %>
      <div>
        <div class="slider-wrapper">
          <div class="main-img-wrapper"></div>
          <div class="main-img-wrapper"></div>
          <div class="main-img-wrapper"></div>
        </div>
        <div style="z-index: 10; height: 700px;">
          <%= render "layouts/header" %>
          <div class="row above-img" style="margin-top: 120px;">
            <div class="col offset-m6 m6">
              <h2 class="center-align white-text">读故事，学英语</h2>
            </div>
          </div>
          <div class="row above-img">
            <div class="col offset-m6 m6">
              <%= link_to new_user_session_path do %>
                <div class="transparent-btn center-align">教师端</div>
              <% end %>
            </div>
          </div>
          <div class="row above-img">
            <div class="col offset-m6 m6">
              <%= link_to new_user_session_path do %>
                <div class="transparent-btn center-align">学员端</div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% else %>
      <%= render "layouts/header" %>
    <% end %>

    <%= yield %>

    <% unless controller_name == "students" and action_name == "me" %>
      <%= render "layouts/footer" %>
    <% end %>
  </body>
</html>
