<div class="bg-light-green page-min-height">

  <%= render "admin/breadcrumb", domain: "students" %>
  <div class="container">
    <div class="row">
      <div class="col m12">
        <br>
        <%= link_to '新学生', new_student_path, class: 'btn' %>
        <table>
          <thead>
            <tr>
              <th>姓</th>
              <th>名字</th>
              <th>年龄</th>
              <th>出生日期</th>
              <th>性别</th>
              <th>城市</th>
              <th colspan="3"></th>
            </tr>
          </thead>

          <tbody>
            <% @students.each do |student| %>
              <tr>
                <td><%= student.lastname %></td>
                <td><%= student.firstname %></td>
                <td><%= student.age %></td>
                <td><%= student.birthday %></td>
                <td><%= student.gender %></td>
                <td><%= student.city %></td>
                <td><%= link_to '查看', student %></td>
                <td><%= link_to '编辑', edit_student_path(student) %></td>
                <td><%= link_to '注销', student, method: :delete, data: { confirm: 'Are you sure?' } %></td>
              </tr>
            <% end %>
          </tbody>
        </table>

        <br>
      </div>
    </div>
  </div>
</div>