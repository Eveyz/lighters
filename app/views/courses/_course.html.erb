<div class="row">
  <div class="col s12 m12">
    <div class="card">
      <div class="card-content">
        <span class="card-title cyan-text" style="font-weight: 400;"><b><%= course.name %></b></span>
        <p>授课老师: <%= Teacher.find(course.teacher_id).fullname %></p>
        <p>课程级别: <%= course.level %></p>
        <p>学生数量: <%= course.students.size %>/<%= course.capacity %></p>
        <p>绘本数量: <%= course.books.size %></p>
      </div>
      <div class="card-action">
        <a class="modal-trigger" href="#editcourse<%= course.id %>">编辑课程</a>
        <%= link_to "添加学生", add_student_course_path(course) %>
        <%= link_to "添加绘本", add_books_course_path(course) %>
        <%= link_to '删除', course, method: :delete, data: { confirm: '你确认要删除嘛?' } %>
      </div>
    </div>
  </div>
</div>

<!-- Modal Structure -->
<div id="editcourse<%= course.id %>" class="modal">
  <div class="modal-content">
    <div class="row">
      <div class="col s12 m10 offset-m1">
        <br>
        <h4>编辑课程</h4>
        <div class="card">
          <div class="card-content" style="padding: 50px;">
            <%= render "courses/form", course: course %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

