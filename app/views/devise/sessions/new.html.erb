<div class="yellow" style="min-height: 700px;">
  <div class="container">
    <br>
    <br>
    <div class="row">
      <div class="col s12 m6 no-padding">
        <div class="shrink-content" style="background-color: #002949;color: white; min-height: 500px;">
          <h3>帮助每个学生成长</h3>
          <ul>
            <li>给学生布置任务</li>
            <li>跟踪每个学生的进度</li>
            <li>加入我们的社区</li>
          </ul>
          <h5>通过注册我们的账号，您同意了我服务条款和隐私条例</h5>
        </div>
      </div>

      <div class="col s12 m6 no-padding">
        <div class="shrink-content" style="background-color: white; min-height: 500px;">
          <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

            <div class="input-field">
              <%= f.email_field :email, autofocus: true, autocomplete: "email", id: :email, placeholder: "example@email.com" %>
              <label for="email">邮箱</label>
            </div>

            <div class="input-field">
              <%= f.password_field :password, autocomplete: "off", id: :password %>
              <label for="password">密码</label>
            </div>

            <% if devise_mapping.rememberable? -%>
              <div class="field">
                <%= f.check_box :remember_me %>
                <%= f.label :remember_me %>
              </div>
            <% end -%>
            <br>

            <div class="actions">
              <%= f.submit "登录", class: 'btn' %>
            </div>
          <% end %>

          <%= render "devise/shared/links" %>
        </div>
      </div>

    </div>

  </div>

</div>

<script>

  document.addEventListener('DOMContentLoaded', function() {
    var elems = document.querySelectorAll('select');
    var instances = M.FormSelect.init(elems, {});
  });

</script>