<div class="bg-light-green page-min-height">

  <%= render "admin/breadcrumb", domain: "dashboard" %>

  <div class="container">
    <br>
    <div class="row">
      <div class="col m12">
        <h6 style="color: rgba(0,0,0,.6);font-weight: 700;">系统管理</h6>
      </div>
    </div>
    <div class="row">
      <%= link_to courses_path do %>
        <div class="col s12 m6">
          <div class="card">
            <div class="card-content" style="padding: 30px;">
              <span class="card-title" style="color: rgba(0,0,0,.6);font-weight: 400;"><b>课程管理</b></span>
              <p><%= @cs %> 个课程</p>
            </div>
          </div>
        </div>
      <% end %>

      <%= link_to teachers_path do %>
        <div class="col s12 m6">
          <div class="card">
            <div class="card-content" style="padding: 30px;">
              <span class="card-title" style="color: rgba(0,0,0,.6);font-weight: 400;"><b>教师管理</b></span>
              <p><%= @th %> 个教师</p>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="row">
      <%= link_to students_path do %>
        <div class="col s12 m6">
          <div class="card">
            <div class="card-content" style="padding: 30px;">
              <span class="card-title" style="color: rgba(0,0,0,.6);font-weight: 400;"><b>学生管理</b></span>
              <p><%= @st %> 个学生</p>
            </div>
          </div>
        </div>
      <% end %>

      <%= link_to books_path do %>
        <div class="col s12 m6">
          <div class="card">
            <div class="card-content" style="padding: 30px;">
              <span class="card-title" style="color: rgba(0,0,0,.6);font-weight: 400;"><b>绘本管理</b></span>
              <p><%= @bk %> 本绘本</p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <br>
    <br>
  </div>
</div>