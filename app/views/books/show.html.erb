<div class="container">

  <p id="notice"><%= notice %></p>
  <div class="row">
    <div class="col s12 m6">
      <div class="card blue-grey darken-1">
        <div class="card-content white-text">
          <span class="card-title"><%= @book.names %></span>
          <p>
            <strong>RAZ等级:</strong>
            <%= @book.rlevel %>
          </p>

          <p>
            <strong>蓝思等级:</strong>
            <%= @book.lslevel %>
          </p>

          <p>
            <strong>年龄段:</strong>
            <%= @book.age %>
          </p>

          <p>
            <strong>绘本分类:</strong>
            <%= @book.category %>
          </p>

          <p>
            <strong>系列名(links):</strong>
            <%= @book.names %>
          </p>

          <p>
            <strong>关键词:</strong>
            <% @keywords.each do |kw| %>
              <div class="chip">
                <%= kw %>
              </div>
            <% end %>
          </p>

          <p>
            <strong>数量/本:</strong>
            <%= @book.quantity %>
          </p>

          <p>
            <strong>书序/名(links):</strong>
            <%= @book.links %>
          </p>

          <p>
            <strong>音频资源:</strong>
            <%= @book.audio %>
          </p>

          <p>
            <strong>推荐备注:</strong>
            <%= @book.rcomments %>
          </p>

          <p>
            <strong>购买备注:</strong>
            <%= @book.bcomments %>
          </p>
        </div>
      </div>
    </div>
  </div>
  
  <%= link_to '编辑', edit_book_path(@book) %> |
  <%= link_to '返回', books_path %>
  <br>
  <br>
  <br>
</div>