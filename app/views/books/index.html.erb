<div class="container">
  <p id="notice"><%= notice %></p>

  <h1>绘本</h1>

  <table>
    <thead>
      <tr>
        <th>RAZ等级</th>
        <th>蓝思等级</th>
        <th>年龄段</th>
        <th>绘本分类</th>
        <th>系列名(links)</th>
        <th>数量</th>
        <th>数量/本</th>
        <th>音频资源</th>
        <th>推荐备注</th>
        <th>购买备注</th>
        <th colspan="3">更多操作</th>
      </tr>
    </thead>

    <tbody>
      <% @books.each do |book| %>
        <tr>
          <td><%= book.rlevel %></td>
          <td><%= book.lslevel %></td>
          <td><%= book.age %></td>
          <td><%= book.category %></td>
          <td><%= book.names %></td>
          <td><%= book.quantity %></td>
          <td><%= book.links %></td>
          <td><%= book.audio %></td>
          <td><%= book.rcomments %></td>
          <td><%= book.bcomments %></td>
          <td>
            <!-- Dropdown Trigger -->
            <a class='dropdown-trigger btn chinese-font cyan' href='#' data-target='moreaction'>更多</a>

            <!-- Dropdown Structure -->
            <ul id='moreaction' class='dropdown-content'>
              <li><%= link_to '查看', book %></li>
              <li><%= link_to '编辑', edit_book_path(book) %></li>
              <li><%= link_to '删除', book, method: :delete, data: { confirm: '你确认要删除嘛?' } %></li>
            </ul>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <br>

  <%= link_to '新书', new_book_path, class: "chinese-font waves-effect waves-light btn" %>
  <br>
  <br>
  <br>
  <br>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var elems = document.querySelectorAll('.dropdown-trigger');
    var instances = M.Dropdown.init(elems, {
      inDuration: 300,
      outDuration: 225,
      constrain_width: false, // Does not change width of dropdown to that of the activator
      hover: false, // Activate on click
      alignment: 'left', // Aligns dropdown to left or right edge (works with constrain_width)
      gutter: 0, // Spacing from edge
      belowOrigin: false // Displays dropdown below the button
    });
  });
</script>